[gd_resource type="Resource" script_class="EventData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/events/event_data.gd" id="1_data"]
[ext_resource type="Script" path="res://scripts/events/event_choice_data.gd" id="2_choice"]

[sub_resource type="Resource" id="Resource_pickup"]
script = ExtResource("2_choice")
label = "Подобрать"
message = "Спасибо."

[sub_resource type="Resource" id="Resource_pass"]
script = ExtResource("2_choice")
label = "Проехать мимо"
message = ""

[resource]
script = ExtResource("1_data")
id = &"hitchhiker"
title = "Автостопщик"
description = "На обочине стоит человек с рюкзаком."
chance = 0.2
cooldown = 500.0
choices = Array[ExtResource("2_choice")]([SubResource("Resource_pickup"), SubResource("Resource_pass")])
